            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts.ps1",
                "logs"
            ],
            "windows": {
                "command": "powershell"
            }
        },
        {
