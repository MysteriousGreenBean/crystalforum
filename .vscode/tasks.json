{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start containers",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts.ps1",
                "start"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "windows": {
                "command": "powershell"
            }
        },
        {
            "label": "Stop containers",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts.ps1",
                "stop"
            ],
            "windows": {
                "command": "powershell"
            }
        },
        {
            "label": "Restart containers",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts.ps1",
                "restart"
            ],
            "windows": {
                "command": "powershell"
            }

        },
        {
